# AdaptixC2 Teamserver connection
ADAPTIX_HOST=127.0.0.1
ADAPTIX_PORT=4321
ADAPTIX_ENDPOINT=/endpoint
ADAPTIX_USE_TLS=true
ADAPTIX_VERIFY_SSL=false

# Operator credentials
ADAPTIX_USERNAME=AdaptixC2_MCP
ADAPTIX_PASSWORD=pass

# Task polling
ADAPTIX_TASK_TIMEOUT=120
ADAPTIX_POLL_INTERVAL=2.0
ADAPTIX_TOKEN_REFRESH_MARGIN=60

# MCP Server
MCP_SERVER_NAME=AdaptixC2
MCP_LOG_LEVEL=INFO

# Transport mode: "stdio" (default, for desktop LLM clients) or "sse" (HTTP)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# API Key for Bearer-token authentication (REQUIRED for SSE transport).
# Generate a strong random value, e.g.:
#   python -c "import secrets; print('sk-' + secrets.token_hex(24))"
# When empty the server starts but logs a warning — all requests proceed
# without any credential check.
MCP_API_KEY=
